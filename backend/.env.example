NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/uaspl_constructos

# Frontend origin allowed to call this API with credentials
CLIENT_URL=http://localhost:8080

# JWT
ACCESS_TOKEN_SECRET=replace_with_a_long_random_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace_with_a_different_long_random_secret
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_REMEMBER_EXPIRES_IN=30d

# Cookies
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Security
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
PASSWORD_RESET_TOKEN_MINUTES=30

# Seed
SEED_SUPER_ADMIN_EMAIL=admin@uaspl.in
SEED_SUPER_ADMIN_PASSWORD= admin@123
